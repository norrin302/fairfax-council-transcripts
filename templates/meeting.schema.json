{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Fairfax Council Transcript Meeting Metadata",
  "description": "Canonical metadata model for a published meeting in this static site.",
  "type": "object",
  "required": [
    "meeting_id",
    "meeting_date",
    "title",
    "meeting_type",
    "city",
    "source_video_url",
    "official_meetings_portal_url",
    "transcript_url",
    "transcript_turns_js",
    "duration_seconds",
    "sections"
  ],
  "properties": {
    "meeting_id": {
      "type": "string",
      "description": "Stable slug id for the meeting (e.g., apr-14-2026)."
    },
    "meeting_date": {
      "type": "string",
      "format": "date",
      "description": "Meeting date in ISO format (YYYY-MM-DD)."
    },
    "display_date": {
      "type": "string",
      "description": "Human-friendly date label used in the UI."
    },
    "title": {
      "type": "string",
      "description": "Full meeting title."
    },
    "meeting_type": {
      "type": "string",
      "enum": ["regular", "work_session", "special", "public_hearing", "other"],
      "description": "Type of meeting."
    },
    "city": {
      "type": "string",
      "default": "Fairfax, VA",
      "description": "City name."
    },
    "source_video_url": {
      "type": "string",
      "format": "uri",
      "description": "Official Granicus clip URL."
    },
    "official_meetings_portal_url": {
      "type": "string",
      "format": "uri",
      "description": "City meetings portal URL (agendas/minutes/media)."
    },
    "official_agenda_url": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "Official agenda link for this meeting (if available)."
    },
    "official_minutes_url": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "Official minutes link for this meeting (if available)."
    },
    "official_packet_url": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "Official packet/supporting docs link (if available)."
    },
    "transcript_url": {
      "type": "string",
      "description": "Published transcript HTML path relative to docs/."
    },
    "transcript_turns_js": {
      "type": "string",
      "description": "Path to the published TRANSCRIPT_TURNS JS file in the repo."
    },
    "duration_seconds": {
      "type": "integer",
      "minimum": 0,
      "description": "Meeting duration in seconds."
    },
    "sections": {
      "type": "array",
      "description": "Agenda/section index points (best source: Granicus clip index).",
      "items": {
        "type": "object",
        "required": ["start_seconds", "label"],
        "properties": {
          "start_seconds": { "type": "integer", "minimum": 0 },
          "label": { "type": "string" }
        }
      }
    }
  }
}

